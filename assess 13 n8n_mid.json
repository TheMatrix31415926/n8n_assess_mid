    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Safe fallback for original node\nlet original = {};\ntry {\n  original = $('Loop Over Items1').first()?.json || {};\n} catch (e) {\n  original = {};\n}\n\nreturn items.map(item => {\n  const d = item.json;\n\n  // Normalize contact number\n  let contactNum = (original['Contact number'] || '')\n    .toString()\n    .trim();\n\n  if (contactNum && !contactNum.startsWith('+')) {\n    contactNum = '+' + contactNum;\n  }\n\n  // Check API success (for each item)\n  const isSuccess = d !== undefined;\n\n  // Unique mock call ID per item\n  const mockCallId = 'MOCK-CALL-' + Date.now() + '-' + d.id;\n\n  return {\n    json: {\n      // From original (DB / sheet)\n      prospect_name: original['Prospect Name'] || '',\n      contact_number: contactNum,\n      email: original['email id'] || '',\n\n      // From API data\n      post_id: d.id,\n      user_id: d.userId,\n      title: d.title,\n      body: d.body?.substring(0, 200),\n\n      // Call tracking\n      call_id: mockCallId,\n      status: isSuccess ? 'Success' : 'Failed',\n      error: isSuccess ? '' : 'Call request failed',\n\n      timestamp: new Date().toISOString()\n    }\n  };\n});"
      },
