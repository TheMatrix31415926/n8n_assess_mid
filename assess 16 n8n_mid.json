    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Safe fallback (no crash if node missing)\nlet original = {};\ntry {\n  original = $('Loop Over Items1').first()?.json || {};\n} catch (e) {\n  original = {};\n}\n\nreturn items.map(item => {\n  const d = item.json;\n\n  // ── BASIC DATA ──\n  const username = d.username || original.username || '';\n  const followers = d.followersCount || 0;\n  const posts = d.postsCount || 0;\n\n  // ── PROFILE URL ──\n  let profileUrl = d.url || original.profile_url || '';\n  if (profileUrl && !profileUrl.startsWith('http')) {\n    profileUrl = 'https://' + profileUrl;\n  }\n\n  // ── PROFILE IMAGE (HD preferred) ──\n  const profileImage =\n    d.hdProfilePicUrl ||\n    d.profilePicUrl ||\n    '';\n\n  // ── CATEGORY ──\n  const category = d.businessCategoryName || 'Not specified';\n\n  // ── ENGAGEMENT (from latest posts) 🔥 ──\n  let avgLikes = 0;\n  let avgComments = 0;\n\n  if (Array.isArray(d.latestPosts) && d.latestPosts.length > 0) {\n    const totalLikes = d.latestPosts.reduce((sum, p) => sum + (p.likesCount || 0), 0);\n    const totalComments = d.latestPosts.reduce((sum, p) => sum + (p.commentsCount || 0), 0);\n\n    avgLikes = Math.round(totalLikes / d.latestPosts.length);\n    avgComments = Math.round(totalComments / d.latestPosts.length);\n  }\n\n  // ── SCORING ──\n  let score = 0;\n\n  // Followers score\n  if (followers > 100000) score += 50;\n  else if (followers > 50000) score += 40;\n  else if (followers > 10000) score += 30;\n  else if (followers > 1000) score += 20;\n  else score += 10;\n\n  // Engagement score 🔥\n  if (avgLikes > 10000) score += 50;\n  else if (avgLikes > 2000) score += 30;\n  else if (avgLikes > 500) score += 20;\n  else score += 10;\n\n  const verified = d.verified || false;\n\n  // ── DUP KEY ──\n  const dupKey = `insta_${username.toLowerCase().trim()}`;\n\n  return {\n    json: {\n      record_id: original.record_id || `REC-${Date.now()}`,\n      username: username,\n      profile_url: profileUrl,\n      profile_image: profileImage, // ✅ new\n      category: category, // ✅ new\n      followers: followers,\n      posts: posts,\n      avg_likes: avgLikes, // ✅ new\n      avg_comments: avgComments, // ✅ new\n      verified: verified,\n      bio: (d.biography || '').substring(0, 200),\n      score: score,\n      search_topic: original.search_topic || '',\n      dup_key: dupKey,\n      timestamp: new Date().toISOString()\n    }\n  };\n});"
      },
