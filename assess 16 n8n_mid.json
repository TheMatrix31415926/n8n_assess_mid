        "jsCode": "const items = $input.all();\n\nreturn items.map((item, index) => {\n  const d = item.json;\n\n  // Validate\n  if (!d.search_topic && !d.record_id) return null;\n\n  // Normalize topic\n  const topic = (d.search_topic || 'unknown')\n    .toLowerCase().trim();\n\n  // Normalize URL\n  let url = (d.profile_url || '').trim();\n  if (url && !url.startsWith('https://')) {\n    url = 'https://' + url;\n  }\n\n  // Extract username from URL\n  const username = url\n    .replace(/https?:\\/\\/(www\\.)?instagram\\.com\\//,'')\n    .replace(/\\//g,'')\n    .trim() || `competitor_${index}`;\n\n  return {\n    json: {\n      record_id: d.record_id || `REC-${Date.now()}`,\n      search_topic: topic,\n      profile_url: url,\n      username: username,\n      title: d.title || `${topic} competitor`,\n      snippet: d.body || 'Competitor in ' + topic,\n      timestamp: new Date().toISOString()\n    }\n  };\n}).filter(Boolean);"
      },
