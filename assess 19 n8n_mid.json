      "parameters": {
        "promptType": "define",
        "text": "=Research this company and extract partner information:\n\nCompany Name: {{ $json.company_name }}\nIndustry: {{ $json.industry }}\nProfile URL: {{ $json.profile_url }}\nRecord ID: {{ $json.record_id }}\n\nReturn ONLY this exact JSON structure:\n{\n  \"record_id\": \"{{ $json.record_id }}\",\n  \"company_name\": \"{{ $json.company_name }}\",\n  \"partner_type\": \"Technology|Reseller|Integration|Referral\",\n  \"website\": \"https://company-website.com\",\n  \"contact_email\": \"partnerships@company.com\",\n  \"industry\": \"{{ $json.industry }}\",\n  \"key_products\": \"Product1, Product2\",\n  \"partnership_potential\": \"High|Medium|Low\",\n  \"notes\": \"One line about why they are a good partner\"\n}",
        "options": {
          "systemMessage": "You are a business research assistant specializing \nin B2B partner companies.\nAlways respond with ONLY a raw JSON object.\nNo markdown, no backticks, no explanation.\nStart with { and end with }"
