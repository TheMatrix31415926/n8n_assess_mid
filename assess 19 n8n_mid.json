    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst original = $('Loop Over Items').first().json;\n\n// Get AI output\nlet rawOutput = item.json.output || '';\nlet partnerData = {};\n\ntry {\n  // Clean markdown if present\n  if (typeof rawOutput === 'string') {\n    rawOutput = rawOutput\n      .replace(/```json/gi, '')\n      .replace(/```/g, '')\n      .trim();\n\n    // Extract JSON object\n    const start = rawOutput.indexOf('{');\n    const end = rawOutput.lastIndexOf('}');\n\n    if (start !== -1 && end !== -1) {\n      partnerData = JSON.parse(\n        rawOutput.substring(start, end + 1)\n      );\n    }\n  } else if (typeof rawOutput === 'object') {\n    partnerData = rawOutput;\n  }\n} catch(e) {\n  // Return safe error record\n  return [{\n    json: {\n      record_id: original.record_id,\n      company_name: original.company_name,\n      error: true,\n      message: 'AI parse failed: ' + e.message,\n      skip: true\n    }\n  }];\n}\n\n// Validate required fields\nif (!partnerData.company_name || \n    !partnerData.partner_type) {\n  return [{\n    json: {\n      record_id: original.record_id,\n      company_name: original.company_name,\n      error: true,\n      message: 'Incomplete AI response',\n      skip: true\n    }\n  }];\n}\n\n// Normalize website URL\nlet website = (partnerData.website || '').trim();\nif (website && !website.startsWith('https://')) {\n  website = 'https://' + website;\n}\n\n// Normalize email\nconst email = (partnerData.contact_email || '')\n  .toLowerCase().trim();\n\n// Normalize partner type\nconst validTypes = [\n  'Technology', 'Reseller', \n  'Integration', 'Referral'\n];\nlet partnerType = (partnerData.partner_type || '')\n  .trim();\nif (!validTypes.includes(partnerType)) {\n  partnerType = 'Technology';\n}\n\n// Normalize potential\nconst validPotential = ['High', 'Medium', 'Low'];\nlet potential = (\n  partnerData.partnership_potential || 'Medium'\n).trim();\nif (!validPotential.includes(potential)) {\n  potential = 'Medium';\n}\n\n// Generate mock Acumatica reference\nconst acuRef = 'ACU-PART-' + Date.now();\n\nreturn [{\n  json: {\n    record_id: original.record_id,\n    company_name: partnerData.company_name,\n    partner_type: partnerType,\n    website: website,\n    contact_email: email,\n    industry: partnerData.industry || \n              original.industry,\n    key_products: partnerData.key_products || '',\n    partnership_potential: potential,\n    notes: partnerData.notes || '',\n    acumatica_ref: acuRef,\n    skip: false,\n    processed_at: new Date().toISOString()\n  }\n}];"
      },
