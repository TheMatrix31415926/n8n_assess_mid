    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const original = item.json;\n  \n  // Get the output string from AI Agent\n  let rawOutput = item.json.output || '';\n  \n  // If output is an object (schema issue), skip it\n  if (typeof rawOutput === 'object') {\n    continue;\n  }\n\n  let competitors = [];\n  \n  try {\n    // Clean the string — remove markdown if any\n    rawOutput = rawOutput\n      .replace(/```json/gi, '')\n      .replace(/```/g, '')\n      .trim();\n\n    // Find the JSON part\n    const jsonStart = rawOutput.indexOf('{');\n    const jsonEnd = rawOutput.lastIndexOf('}');\n    \n    if (jsonStart !== -1 && jsonEnd !== -1) {\n      const jsonString = rawOutput.substring(jsonStart, jsonEnd + 1);\n      const parsed = JSON.parse(jsonString);\n      competitors = parsed.competitors || [];\n    }\n  } catch(e) {\n    continue; // skip this item if parse fails\n  }\n\n  // Deduplicate\n  const seen = new Set();\n\n  for (const c of competitors) {\n    const key = (c.name || '').toLowerCase().trim();\n    \n    if (!seen.has(key) && key !== '') {\n      seen.add(key);\n\n      // Normalize website\n      let website = (c.website || '').trim();\n      if (website && !website.startsWith('https://')) {\n        website = 'https://' + website;\n      }\n\n      // Normalize Instagram handle\n      let handle = (c.instagram_handle || '').trim();\n      if (handle && !handle.startsWith('@')) {\n        handle = '@' + handle;\n      }\n\n      // Score based on followers\n      const followers = Number(c.estimated_followers) || 0;\n      let score = 40;\n      if (followers > 100000) score = 100;\n      else if (followers > 50000) score = 80;\n      else if (followers > 10000) score = 60;\n\n      results.push({\n        json: {\n          message_id: original.message_id || 'MSG-001',\n          company_name: c.name,\n          website: website,\n          instagram_handle: handle,\n          description: c.description || '',\n          estimated_followers: followers,\n          source_company: original.company_name || '',\n          qualification_score: score,\n          processed_at: new Date().toISOString()\n        }\n      });\n    }\n  }\n}\n\n// Safety check\nif (results.length === 0) {\n  return [{\n    json: {\n      error: true,\n      message: 'AI did not return valid competitor data',\n      tip: 'Check AI Agent prompt and turn OFF Require Specific Output Format'\n    }\n  }];\n}\n\nreturn results;"
      },
