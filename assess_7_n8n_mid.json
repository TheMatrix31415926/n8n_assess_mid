    {
      "parameters": {
        "promptType": "define",
        "text": "=Company: {{ $json.company_name }}\n\nFind top 3 competitors for this company.\nYou MUST return ONLY this exact JSON structure.\nNo explanation. No markdown. No backticks.\nJust the raw JSON starting with { :\n\n{\n  \"competitors\": [\n    {\n      \"name\": \"ActualCompanyName\",\n      \"website\": \"https://actualwebsite.com\",\n      \"instagram_handle\": \"@actualhandle\",\n      \"description\": \"one line about what they do\",\n      \"estimated_followers\": 75000\n    },\n    {\n      \"name\": \"ActualCompanyName2\",\n      \"website\": \"https://actualwebsite2.com\",\n      \"instagram_handle\": \"@actualhandle2\",\n      \"description\": \"one line about what they do\",\n      \"estimated_followers\": 50000\n    },\n    {\n      \"name\": \"ActualCompanyName3\",\n      \"website\": \"https://actualwebsite3.com\",\n      \"instagram_handle\": \"@actualhandle3\",\n      \"description\": \"one line about what they do\",\n      \"estimated_followers\": 30000\n    }\n  ]\n}",
        "options": {
          "systemMessage": "You are a competitor research assistant.\nAlways respond ONLY in valid JSON.\nNo extra text. No markdown. Just raw JSON."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
