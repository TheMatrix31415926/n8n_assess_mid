      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const d = item.json;\n\n  // Get company name from whatever field exists\n  // Check all possible field names from your Postgres/Sheet data\n  const companyName = \n    d.company_name ||    // from postgres\n    d.name ||            // alternative\n    d.subject ||         // from your input example\n    'Unknown Company';\n\n  return {\n    json: {\n      ...d,\n      company_name: companyName,           // ← AI Agent needs this\n      search_context: 'competitor analysis instagram influencer', // ← AI Agent needs this\n      company_name_normalized: companyName.trim().toLowerCase().replace(/\\s+/g, '-'),\n      search_timestamp: new Date().toISOString(),\n      validation_status: companyName !== 'Unknown Company' ? 'VALID' : 'INVALID'\n    }\n  };\n});"
      },
