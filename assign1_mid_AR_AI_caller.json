    {
      "parameters": {
        "jsCode": "// Normalize and enrich each record\nconst items = $input.all();\n\nreturn items.map(item => {\n  const record = item.json;\n  \n  // Normalize phone number (strip spaces, ensure + prefix)\n  let phone = (record.phone || '').replace(/\\s+/g, '');\n  if (!phone.startsWith('+')) phone = '+' + phone;\n  \n  // Normalize email to lowercase\n  const email = (record.email || '').toLowerCase().trim();\n  \n  // Format amount to 2 decimal places string\n  const amount = parseFloat(record.amount || 0).toFixed(2);\n  \n  // Flag overdue\n  const dueDate = new Date(record.due_date);\n  const today = new Date();\n  const isOverdue = dueDate < today;\n  \n  return {\n    json: {\n      ...record,\n      phone_normalized: phone,\n      email_normalized: email,\n      amount_display: `$${amount}`,\n      is_overdue: isOverdue,\n      overdue_days: isOverdue ? Math.floor((today - dueDate) / (1000 * 60 * 60 * 24)) : 0,\n      source_event: $('Webhook').first().json.event_id\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        -144
      ],
      "id": "beeb4b75-fc74-4acd-9c73-d32fd73beef2",
      "name": "Code - Transform Records"
