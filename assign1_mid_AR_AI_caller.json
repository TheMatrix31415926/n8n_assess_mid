    {
      "parameters": {
        "jsCode": "// Validate required fields before any irreversible action\nconst items = $input.all();\nconst validItems = [];\nconst invalidItems = [];\n\nfor (const item of items) {\n  const d = item.json;\n  \n  // Skip items that are just the webhook payload (no invoice_number)\n  if (!d.invoice_number) continue;\n  \n  const missing = [];\n  if (!d.customer_name) missing.push('customer_name');\n  if (!d.phone_normalized) missing.push('phone');\n  if (!d.email_normalized) missing.push('email');\n  if (!d.amount) missing.push('amount');\n  if (!d.invoice_number) missing.push('invoice_number');\n  \n  if (missing.length > 0) {\n    invalidItems.push({\n      json: { ...d, validation_status: 'INVALID', missing_fields: missing }\n    });\n  } else {\n    validItems.push({\n      json: { ...d, validation_status: 'VALID' }\n    });\n  }\n}\n\n// Return only valid items downstream\n// Invalid ones are logged (you can add a branch later)\nif (validItems.length === 0) {\n  throw new Error('No valid records found to process');\n}\n\nreturn validItems;"
      },
