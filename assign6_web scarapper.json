    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst original = $('Loop Over Items').first().json;\n\nreturn items.map(item => {\n  const d = item.json;\n  \n  const followersCount = d.followersCount || 0;\n  const followsCount = d.followsCount || 1;\n  const postsCount = d.postsCount || 0;\n  \n  // Qualification scoring\n  let score = 0;\n  if (followersCount > 10000) score += 40;\n  else if (followersCount > 1000) score += 20;\n  if (postsCount > 50) score += 20;\n  const engagementRate = followersCount > 0 \n    ? ((d.likesCount || 0) / followersCount * 100).toFixed(2) \n    : 0;\n  if (engagementRate > 3) score += 40;\n  else if (engagementRate > 1) score += 20;\n\n  return {\n    json: {\n      user_id: original.user_id,\n      username: d.username || original.username,\n      platform: 'instagram',\n      profile_url: d.url || original.profile_url,\n      full_name: d.fullName || '',\n      followers: followersCount,\n      following: followsCount,\n      posts_count: postsCount,\n      bio: d.biography || '',\n      engagement_rate: engagementRate,\n      qualification_score: score,\n      qualified: score >= 60,\n      caption: original.caption,\n      processed_at: new Date().toISOString()\n    }\n  };\n});"
      },
