      "parameters": {
        "jsCode": "const items = $input.all();\nconst valid = [];\n\nfor (const item of items) {\n  const d = item.json;\n  const missing = [];\n\n  if (!d.user_id) missing.push('user_id');\n  if (!d.username) missing.push('username');\n  if (!d.profile_url) missing.push('profile_url');\n\n  // Normalize Instagram URL\n  let url = (d.profile_url || '').trim();\n  if (!url.startsWith('https://')) url = 'https://' + url;\n  if (!url.endsWith('/')) url = url + '/';\n\n  if (missing.length === 0) {\n    valid.push({\n      json: {\n        ...d,\n        profile_url: url,\n        validation_status: 'VALID'\n      }\n    });\n  }\n}\n\nif (valid.length === 0) throw new Error('No valid records to process');\nreturn valid;"
      },
