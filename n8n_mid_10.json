    {
      "parameters": {
        "jsCode": "// ICE Score Calculator Tool\n// Impact x Confidence / Effort\nconst impact = $input.first().json.impact || 7;\nconst confidence = $input.first().json.confidence || 7;\nconst effort = $input.first().json.effort || 5;\n\nconst iceScore = Math.round(\n  (impact * confidence) / effort\n);\n\nreturn [{ json: { ice_score: iceScore } }];"
      },
      "type": "@n8n/n8n-nodes-langchain.toolCode",
      "typeVersion": 1.3,
      "position": [
        864,
        416
      ],
      "id": "cf2cf534-414b-476a-b3b1-f45d0e3f107f",
      "name": "Code Tool"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst original = item.json;\n\n// Get AI output\nlet rawOutput = item.json.output || '';\n\nlet recommendations = [];\n\ntry {\n  // Clean the output\n  if (typeof rawOutput === 'string') {\n    // Remove markdown if present\n    rawOutput = rawOutput\n      .replace(/```json/gi, '')\n      .replace(/```/g, '')\n      .trim();\n\n    // Find the JSON array\n    const start = rawOutput.indexOf('[');\n    const end = rawOutput.lastIndexOf(']');\n\n    if (start !== -1 && end !== -1) {\n      const jsonStr = rawOutput.substring(start, end + 1);\n      recommendations = JSON.parse(jsonStr);\n    }\n  } else if (Array.isArray(rawOutput)) {\n    recommendations = rawOutput;\n  } else if (rawOutput.recommendations) {\n    recommendations = rawOutput.recommendations;\n  }\n} catch(e) {\n  // Return error info safely\n  return [{\n    json: {\n      error: true,\n      message: 'AI output could not be parsed: ' + e.message,\n      raw: JSON.stringify(rawOutput).substring(0, 300)\n    }\n  }];\n}\n\n// Validate and clean each recommendation\nconst valid = [];\nconst allowedCategories = [\n  'Content', 'SEO', 'Paid', 'Social', 'Email', 'Brand'\n];\nconst allowedPriorities = ['High', 'Medium', 'Low'];\n\nfor (const rec of recommendations) {\n\n  // Skip incomplete records\n  if (!rec.title || !rec.rationale) continue;\n\n  // Normalize category\n  let category = (rec.category || 'Content').trim();\n  if (!allowedCategories.includes(category)) {\n    category = 'Content';\n  }\n\n  // Normalize priority\n  let priority = (rec.priority || 'Medium').trim();\n  if (!allowedPriorities.includes(priority)) {\n    priority = 'Medium';\n  }\n\n  // Normalize ICE score (must be 1-100)\n  let iceScore = Number(rec.ice_score) || 50;\n  if (iceScore > 100) iceScore = 100;\n  if (iceScore < 1) iceScore = 1;\n\n  // Normalize due days\n  let dueDays = Number(rec.due_days) || 14;\n  if (dueDays < 1) dueDays = 7;\n  if (dueDays > 90) dueDays = 90;\n\n  valid.push({\n    json: {\n      title: rec.title.substring(0, 150),\n      rationale: (rec.rationale || '').substring(0, 300),\n      category: category,\n      priority: priority,\n      ice_score: iceScore,\n      owner_role: rec.owner_role || 'Marketing Manager',\n      due_days: dueDays,\n      source_insight: rec.source_insight || \n        original.Topic || 'Unknown',\n      generated_at: new Date().toISOString()\n    }\n  });\n}\n\n// Safety check — don't write garbage to sheet\nif (valid.length === 0) {\n  return [{\n    json: {\n      error: true,\n      message: 'No valid recommendations after validation',\n      raw: JSON.stringify(rawOutput).substring(0, 300)\n    }\n  }];\n}\n\nreturn valid;"
      },
