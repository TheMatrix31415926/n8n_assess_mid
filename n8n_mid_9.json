    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Get original record from Postgres node\nconst original = $('Postgres').first().json;\n\nreturn items.map(item => {\n  const d = item.json;\n\n  // Validate post data\n  if (!d.url && !d.shortCode) {\n    return {\n      json: {\n        error: true,\n        message: 'Invalid post data',\n        message_id: original.message_id\n      }\n    };\n  }\n\n  // Normalize post URL\n  let postUrl = d.url || \n    `https://www.instagram.com/p/${d.shortCode}/`;\n  if (!postUrl.startsWith('https://')) {\n    postUrl = 'https://' + postUrl;\n  }\n\n  // Extract metrics\n  const likes = d.likesCount || 0;\n  const comments = d.commentsCount || 0;\n  const followers = d.ownerFollowersCount || 1;\n\n  // Engagement rate calculation\n  const engagementRate = followers > 0\n    ? (((likes + comments) / followers) * 100).toFixed(2)\n    : 0;\n\n  // Score based on engagement\n  let score = 0;\n  if (engagementRate > 5) score = 100;\n  else if (engagementRate > 3) score = 80;\n  else if (engagementRate > 1) score = 60;\n  else score = 30;\n\n  // Normalize caption\n  const caption = (d.caption || '')\n    .substring(0, 200)\n    .replace(/\\n/g, ' ')\n    .trim();\n\n  return {\n    json: {\n      message_id: original.message_id || 'MSG-001',\n      username: d.ownerUsername || original.username,\n      post_url: postUrl,\n      caption: caption,\n      likes: likes,\n      comments: comments,\n      post_type: d.type || 'Image',\n      engagement_rate: engagementRate,\n      engagement_score: score,\n      platform: 'instagram',\n      timestamp: new Date().toISOString()\n    }\n  };\n});"
      },
