      "parameters": {
        "jsCode": "const items = $input.all();\nconst original = $('Postgres1').first().json;\n\nreturn items.map(item => {\n  const d = item.json;\n\n  if (!d.url && !d.id) {\n    return {\n      json: {\n        error: true,\n        message: 'Invalid LinkedIn post data',\n        message_id: original.message_id\n      }\n    };\n  }\n\n  // Normalize post URL\n  let postUrl = (d.url || d.postUrl || '').trim();\n  if (postUrl && !postUrl.startsWith('https://')) {\n    postUrl = 'https://' + postUrl;\n  }\n\n  // Extract metrics\n  const reactions = d.likesCount || d.reactions || 0;\n  const comments = d.commentsCount || d.comments || 0;\n\n  // Score\n  let score = 0;\n  if (reactions > 1000) score = 100;\n  else if (reactions > 500) score = 80;\n  else if (reactions > 100) score = 60;\n  else score = 30;\n\n  // Normalize content\n  const content = (d.text || d.content || '')\n    .substring(0, 200)\n    .replace(/\\n/g, ' ')\n    .trim();\n\n  return {\n    json: {\n      message_id: original.message_id || 'MSG-002',\n      name: d.authorName || original.username || '',\n      post_url: postUrl,\n      content: content,\n      reactions: reactions,\n      comments: comments,\n      post_score: score,\n      platform: 'linkedin',\n      timestamp: new Date().toISOString()\n    }\n  };\n});"
