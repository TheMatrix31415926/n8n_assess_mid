    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst valid = [];\n\nfor (const item of items) {\n  const d = item.json;\n  const missing = [];\n\n  if (!d.message_id) missing.push('message_id');\n  if (!d.username) missing.push('username');\n  if (!d.profile_url) missing.push('profile_url');\n\n  if (missing.length > 0) continue; // skip invalid\n\n  // Normalize URL\n  let url = (d.profile_url || '').trim();\n  if (!url.startsWith('https://')) url = 'https://' + url;\n  if (!url.endsWith('/')) url = url + '/';\n\n  valid.push({\n    json: { ...d, profile_url: url, validation_status: 'VALID' }\n  });\n}\n\nif (valid.length === 0) {\n  throw new Error('No valid Instagram records found');\n}\n\nreturn valid;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
